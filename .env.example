# Cross-Border Closing Agent — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local

# ─── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe (MVP payment provider) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Create these in Stripe Dashboard (sandbox) → Products → Add product
STRIPE_PRICE_BROKER_ID=price_your-broker-price-id
STRIPE_PRICE_DEVELOPER_ID=price_your-developer-price-id

# ─── WhatsApp Business API (Meta) ────────────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-custom-verify-token

# ─── Unifonic (Saudi OTP/SMS) ────────────────────────────────────
UNIFONIC_API_KEY=your-unifonic-api-key
UNIFONIC_SENDER_ID=your-sender-id

# ─── Email (Mailgun or Resend) ───────────────────────────────────
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
# Alternative: RESEND_API_KEY=re_your-resend-api-key

# ─── Sentry (error monitoring) ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# Set to "1" in staging to enable /api/sentry-test endpoint
ENABLE_SENTRY_TEST=

# ─── PostHog (analytics) ─────────────────────────────────────────
# Server-side (used in API routes + webhooks)
POSTHOG_API_KEY=phc_your-posthog-key
POSTHOG_HOST=https://app.posthog.com
# Client-side (for posthog-js browser SDK)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Claude API (AI qualification logic) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
